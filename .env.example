# ============================================================================
# AI Destekli Web Zafiyet Tarayıcısı — Yapılandırma
# ============================================================================
# Bu dosyayı `.env` olarak kopyalayın ve ihtiyacınıza göre düzenleyin:
#
#   cp .env.example .env
#
# Ardından `docker compose up -d` ile başlatın.
# ============================================================================


# ----------------------------------------------------------------------------
# LLM modelleri (otomatik indirilecek)
# ----------------------------------------------------------------------------
# Boşlukla ayrılmış model listesi. Container ilk başladığında ollama-init
# servisi bu modelleri otomatik indirir.
#
# nomic-embed-text MUTLAKA listede olmalı — RAG için kullanılır (sadece 274 MB).
#
# Örnekler:
#   - Minimum kurulum (~5 GB toplam):
#       OLLAMA_PULL_MODELS=llama3 nomic-embed-text
#
#   - Küçük modellerle çoklu karşılaştırma (~6 GB):
#       OLLAMA_PULL_MODELS=qwen2.5:3b phi3:mini gemma2:2b nomic-embed-text
#
#   - Tam karşılaştırma kurulumu (~15 GB):
#       OLLAMA_PULL_MODELS=llama3 qwen2.5:7b mistral phi3:mini nomic-embed-text
#
# Popüler modeller (Ollama'da):
#   llama3              4.7 GB   (Meta'nın güçlü genel modeli)
#   qwen2.5:3b          2.0 GB   (JSON üretmede tutarlı, Türkçe iyi)
#   qwen2.5:7b          4.7 GB   (Daha derin analiz)
#   phi3:mini           2.3 GB   (Microsoft, kod yorumlama iyi)
#   gemma2:2b           1.6 GB   (Google, en küçük + hızlı)
#   gemma2:9b           5.4 GB   (Google, daha derin)
#   mistral:7b          4.1 GB   (Klasik karşılaştırma modeli)
#   deepseek-coder      1.0 GB   (Kod odaklı küçük model)
#   nomic-embed-text    274 MB   (Embedding, RAG için ZORUNLU)
# ----------------------------------------------------------------------------
OLLAMA_PULL_MODELS=llama3 nomic-embed-text


# ----------------------------------------------------------------------------
# Eş zamanlı tarama limiti
# ----------------------------------------------------------------------------
# Aynı anda çalışacak maksimum tarama sayısı.
MAX_CONCURRENT_SCANS=3


# ----------------------------------------------------------------------------
# Web UI portu
# ----------------------------------------------------------------------------
# nginx host port (varsayılan 9000). Tarayıcı: http://localhost:${WEB_PORT}
WEB_PORT=9000


# ----------------------------------------------------------------------------
# GPU desteği (opsiyonel — NVIDIA Container Toolkit gerekli)
# ----------------------------------------------------------------------------
# GPU varsa LLM yanıtları 5-10x hızlanır. Etkinleştirmek için:
#   1. NVIDIA Container Toolkit kurun: https://docs.nvidia.com/datacenter/cloud-native/container-toolkit/
#   2. Aşağıdaki satırın yorumunu kaldırın:
# OLLAMA_GPU=all
